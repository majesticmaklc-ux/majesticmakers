# ============================================
# MAJESTIC MAKERS - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB (default - easy to run locally with `mongod`)
MONGODB_URI=mongodb://localhost:27017/majestic_makers

# ----------- OR use Elasticsearch -----------
# Set USE_ELASTICSEARCH=true to switch to Elasticsearch
USE_ELASTICSEARCH=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=majestic_makers

# Email Configuration (Gmail example)
# For Gmail: enable "App Passwords" in your Google Account
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Majestic Makers <your_email@gmail.com>
COMPANY_EMAIL=contact@majesticmakers.com

# JWT Secret (for admin auth)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Credentials (change before going live!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@Majestic2024
